---
const tourHref = 'https://virtuslab.com/lp/visdom-tour-2026';
---
<a
  class="tour-banner"
  href={tourHref}
  target="_blank"
  rel="noopener"
  data-cta="cta_click"
  aria-label="Visdom AI Tour 2026, see the dates and register"
>
  <span class="tour-banner-tag">Visdom AI Tour</span>
  <span class="tour-banner-text">
    <span class="tour-stop tour-stop--upcoming"><span class="tour-flag">🇨🇭</span>Zurich <span class="tour-month">May</span></span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop tour-stop--upcoming"><span class="tour-flag">🇺🇸</span>New York <span class="tour-month">June</span></span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop tour-stop--next"><span class="tour-flag">🇺🇸</span><strong>New York</strong> <span class="tour-next-badge">Next stop: September</span></span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop tour-stop--upcoming"><span class="tour-flag">🇺🇸</span>San Francisco <span class="tour-month">October</span></span>
  </span>
</a>

<style>
  .tour-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 9px 20px;
    background: linear-gradient(90deg, #ecfdf5, #eff6ff);
    border-bottom: 1px solid color-mix(in oklab, var(--color-emerald, #10b981) 22%, transparent);
    color: #0f172a;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.3;
    text-align: center;
    transition: filter 0.2s ease;
  }

  .tour-banner:hover {
    filter: brightness(0.98);
  }

  .tour-banner-tag {
    flex-shrink: 0;
    padding: 2px 9px;
    border-radius: 9999px;
    background: var(--color-emerald, #10b981);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tour-banner-text {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 5px 9px;
    font-size: 0.78rem;
  }

  .tour-banner-text strong {
    font-weight: 700;
  }

  .tour-stop {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }

  .tour-flag {
    font-size: 0.95em;
    line-height: 1;
  }

  .tour-sep {
    opacity: 0.55;
  }

  .tour-stop--upcoming {
    color: color-mix(in oklab, #0f172a 62%, transparent);
  }

  .tour-stop--next {
    font-weight: 700;
  }

  .tour-next-badge {
    display: inline-flex;
    align-items: center;
    margin-left: 2px;
    color: var(--color-emerald-dark, #047857);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .tour-next-badge::before {
    content: "";
    width: 4px;
    height: 4px;
    margin-right: 5px;
    border-radius: 9999px;
    background: var(--color-emerald, #10b981);
  }

  .tour-month {
    display: inline-flex;
    align-items: center;
    margin-left: 1px;
    padding: 1px 6px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-emerald, #10b981) 14%, transparent);
    color: var(--color-emerald-dark, #047857);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

</style>
