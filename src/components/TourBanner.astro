---
const tourHref = 'https://virtuslab.com/lp/visdom-tour-2026';
---
<a
  class="tour-banner"
  href={tourHref}
  target="_blank"
  rel="noopener"
  data-cta="cta_click"
  aria-label="Visdom AI Tour 2026, see the dates and register"
>
  <span class="tour-banner-tag">Visdom AI Tour</span>
  <span class="tour-banner-text">
    <span class="tour-stop"><span class="tour-flag">🇵🇱</span>Kraków</span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop"><span class="tour-flag">🇵🇱</span>Warsaw</span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop"><span class="tour-flag">🇨🇭</span>Zurich</span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop"><span class="tour-flag">🇺🇸</span>New York</span>
    <span class="tour-sep" aria-hidden="true">·</span>
    <span class="tour-stop"><span class="tour-flag">🇬🇧</span><strong>London</strong></span>
  </span>
  <span class="tour-banner-cta" aria-hidden="true">
    Learn more
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
  </span>
</a>

<style>
  .tour-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 9px 20px;
    background: linear-gradient(90deg, #ecfdf5, #eff6ff);
    border-bottom: 1px solid color-mix(in oklab, var(--color-emerald, #10b981) 22%, transparent);
    color: #0f172a;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.3;
    text-align: center;
    transition: filter 0.2s ease;
  }

  .tour-banner:hover {
    filter: brightness(0.98);
  }

  .tour-banner-tag {
    flex-shrink: 0;
    padding: 2px 9px;
    border-radius: 9999px;
    background: var(--color-emerald, #10b981);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tour-banner-text {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 12px;
  }

  .tour-banner-text strong {
    font-weight: 700;
  }

  .tour-stop {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
  }

  .tour-flag {
    font-size: 1.05em;
    line-height: 1;
  }

  .tour-sep {
    opacity: 0.55;
  }

  .tour-banner-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .tour-banner-cta {
      display: none;
    }
  }
</style>
