---
const BASE = 'https://virtuslab.com';

const series = [
  {
    title: 'VISDOM',
    color: 'var(--color-emerald)',
    description: 'Field notes on agent-ready SDLC, context, CI, review, and governance.',
    latest: {
      title: 'AI in the SDLC: Faster or Just Busier?',
      date: 'Apr 10, 2026',
      href: `${BASE}/blog/ai/ai-in-the-sdlc-faster-or-just-busier/`,
      image: 'blog-visdom.jpg',
    },
    linkLabel: 'Read latest article',
  },
  {
    title: 'GitHub All-Stars',
    color: 'var(--color-blue)',
    description: 'What we watch in open source and why it matters.',
    latest: {
      title: '#16: Project N.O.M.A.D. - Civilization in a Docker Container',
      date: 'Mar 25, 2026',
      href: `${BASE}/blog/ai/project-nomad/`,
      image: 'blog-github-all-stars.jpg',
    },
    linkLabel: 'Read latest article',
  },
  {
    title: 'AI-Insight',
    color: 'var(--color-purple)',
    description: 'Technical analysis of models, systems, and engineering patterns.',
    latest: {
      title: 'Interview with Krzysztof Grajek, lead engineer behind TraceVault',
      date: 'Apr 13, 2026',
      href: `${BASE}/blog/ai/interview-with-krzysztof-grajek-lead-engineer-behind-trace-vault/`,
      image: 'blog-ai-insight.jpg',
    },
    linkLabel: 'Read latest article',
  },
];
---
<section class="section" id="insights">
  <div class="container">
    <div id="thesis" class="fade-up writing-head">
      <p class="section-label">Public writing</p>
      <h2 class="section-title">We publish the thesis before we pitch the engagement.</h2>
      <p class="section-subtitle">
        50+ articles across three series. Read the argument, then decide.
      </p>
    </div>

    <div class="writing-grid">
      {series.map((item) => (
        <article class="writing-card fade-up">
          <a href={item.latest.href} target="_blank" rel="noopener" class="writing-thumb" aria-label={item.latest.title}>
            <img src={`${import.meta.env.BASE_URL}/${item.latest.image}`} alt="" loading="lazy" width="1200" height="627" />
          </a>
          <div class="writing-card-line" style={`background: ${item.color}`}></div>
          <p class="writing-series">{item.title}</p>
          <p class="writing-description">{item.description}</p>
          <a href={item.latest.href} target="_blank" rel="noopener" class="writing-latest">
            <span class="writing-latest-label">Latest</span>
            <span class="writing-latest-title">{item.latest.title}</span>
            <span class="writing-latest-date">{item.latest.date}</span>
          </a>
          <a href={item.latest.href} target="_blank" rel="noopener" class="btn-pill btn-outline writing-link">{item.linkLabel} -&gt;</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .writing-head {
    max-width: 40rem;
    margin-bottom: 2.75rem;
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .writing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--card);
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05);
    overflow: hidden;
  }

  .writing-thumb {
    display: block;
    margin: -1.5rem -1.5rem 0;
    aspect-ratio: 1200 / 627;
    overflow: hidden;
    background: var(--color-surface);
  }

  .writing-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .writing-thumb:hover img {
    transform: scale(1.02);
  }

  .writing-card-line {
    width: 100%;
    height: 3px;
    border-radius: 999px;
  }

  .writing-series {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .writing-description {
    margin: 0;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .writing-latest {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border-radius: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .writing-latest:hover {
    border-color: var(--color-emerald);
    transform: translateY(-1px);
  }

  .writing-latest-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .writing-latest-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-text);
  }

  .writing-latest-date {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .writing-link {
    align-self: flex-start;
  }

  @media (max-width: 1023px) {
    .writing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
