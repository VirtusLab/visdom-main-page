---
const pillars = [
  {
    icon: '{}',
    title: 'Context Fabric',
    description: 'Structured, agent-consumable context that turns tribal knowledge into machine-readable specifications. Your AI agents finally understand your codebase, architecture, and business rules.',
  },
  {
    icon: '>>',
    title: 'Machine-Speed CI',
    description: 'High-frequency iteration loops designed for agent-driven development. Sub-minute feedback cycles that let AI agents ship, test, and iterate at the speed they were designed for.',
  },
  {
    icon: '!!',
    title: 'Automated Risk Assessment',
    description: 'Continuous validation that catches what AI misses. Automated security scanning, architectural compliance, and quality gates that scale with your AI-generated output.',
  },
];
---
<section class="section" id="pillars">
  <div class="container">
    <div class="text-center mb-16 fade-up">
      <h2 class="section-title">Three Pillars of Agent-Ready Infrastructure</h2>
      <p class="section-subtitle mx-auto">
        The foundation every engineering team needs before AI agents can deliver real value.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {pillars.map(pillar => (
        <div class="glass-card p-8 fade-up">
          <div class="text-2xl mb-4 text-emerald" style="font-family: var(--font-mono);">
            {pillar.icon}
          </div>
          <h3 class="text-xl font-bold text-white mb-3" style="font-family: var(--font-heading);">
            {pillar.title}
          </h3>
          <p class="text-sm text-white/50 leading-relaxed">
            {pillar.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
