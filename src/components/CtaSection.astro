---
import { CtaCard } from '@virtuslab/visdom-ui';
---
<section id="contact" class="section">
  <div class="container text-center">
    <p class="section-label">Get Started</p>
    <h2 class="section-title mx-auto">Ready to make your SDLC agent-ready?</h2>
    <p class="section-subtitle mx-auto mb-16">Start where it makes sense.</p>
    <div class="grid sm:grid-cols-3 gap-8 max-w-3xl mx-auto">
      <CtaCard
        icon="&#x2699;"
        title="Try ViDIA"
        description="Open source. Start in 5 minutes."
        href="https://github.com/VirtusLab/visdom-developer-intelligence"
        external
        client:load
      />
      <CtaCard
        icon="&#x1F4CA;"
        title="Take the Assessment"
        description="60 practices. Know where you stand."
        href="https://visdom-ai-maturity-matrix.pages.dev/assessment"
        external
        client:load
      />
      <CtaCard
        icon="&#x1F4AC;"
        title="Talk to Engineers"
        description="Not sales. Engineers who built this."
        href="https://virtuslab.com/contact"
        external
        highlighted
        client:load
      />
    </div>
  </div>
</section>
