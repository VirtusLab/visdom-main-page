---
import Terminal from './Terminal.astro';
---
<section id="platform" class="section">
  <div class="container">
    <p class="section-label">Platform Components</p>
    <h2 class="section-title">Everything your agents need to ship with confidence</h2>
    <p class="section-subtitle mb-24">
      Each component works standalone. Together, they form an Agent-Ready SDLC.
    </p>

    {/* Component Grid - clean, spacious */}
    <div class="space-y-24">

      {/* 01 - Maturity Matrix */}
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-5xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">01</span>
          <h3 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: var(--font-heading);">Maturity Matrix</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            60 practices across 4 perspectives and 5 maturity levels. Know exactly where your organization stands on AI readiness - and what to improve next.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="tag bg-blue/10 text-blue border border-blue/20">Interactive Assessment</span>
            <span class="tag bg-emerald/10 text-emerald border border-emerald/20">Workshop Mode</span>
          </div>
          <div class="flex gap-3">
            <a href="https://visdom-ai-maturity-matrix.pages.dev/assessment" target="_blank" rel="noopener" class="btn-pill btn-primary text-sm">Try the Assessment</a>
            <a href="https://visdom-ai-maturity-matrix.pages.dev/matrix/development" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">Explore Matrix</a>
          </div>
        </div>
        <div class="surface-card p-8 flex items-center justify-center">
          <div class="flex items-center gap-2">
            {['Ad-hoc', 'Guided', 'Systematic', 'Optimized', 'Autonomous'].map((level, i) => (
              <div class="flex items-center gap-2">
                <div class="text-center px-3 py-2 rounded-lg" style={`background: ${['#f4f4f5','#ccfbf1','#d1fae5','#dcfce7','#bbf7d0'][i]}`}>
                  <div class="text-xs font-bold" style={`color: ${['#71717a','#0d9488','#059669','#16a34a','#22c55e'][i]}`}>L{i+1}</div>
                  <div class="text-[10px]" style={`color: ${['#71717a','#0d9488','#059669','#16a34a','#22c55e'][i]}; opacity: 0.7`}>{level}</div>
                </div>
                {i < 4 && <div class="w-4 h-px bg-border"></div>}
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* 02 - Context Fabric */}
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <Terminal title="context-fabric">
{`$ vidia init
Scanning repository...
Detected: pyproject.toml, .pre-commit-config.yaml,
          GitHub Actions, Docker Compose, ArchUnit
Found 23 rules across 6 categories.
Exported to CLAUDE.md `}<span class="text-emerald">&#x2713;</span>
          </Terminal>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-5xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">02</span>
          <h3 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: var(--font-heading);">Context Fabric</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            Structured, agent-consumable context built across repositories and teams. Your agents stop hallucinating when they can actually see your codebase.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="tag bg-purple/10 text-purple border border-purple/20">Infrastructure</span>
            <span class="tag bg-emerald/10 text-emerald border border-emerald/20">16+ Config Detectors</span>
          </div>
          <a href="https://github.com/VirtusLab" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">View on GitHub &rarr;</a>
        </div>
      </div>

      {/* 03 - Machine-Speed CI */}
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-5xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">03</span>
          <h3 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: var(--font-heading);">Machine-Speed CI</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            Your CI takes 45 minutes. An AI agent iterates 50x per hour. We re-architect your pipeline to match agent speed.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="tag bg-purple/10 text-purple border border-purple/20">Bazel</span>
            <span class="tag bg-purple/10 text-purple border border-purple/20">Gradle</span>
            <span class="tag bg-amber/10 text-amber border border-amber/20">Performance</span>
          </div>
          <a href="https://virtuslab.com/blog/ai/the-fallacy/" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">Read: "The Ferrari Engine in a Fiat 500" &rarr;</a>
        </div>
        <div class="surface-card p-8">
          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Build time</span><span class="font-semibold text-emerald">-88%</span></div>
              <div class="h-2 bg-surface-light rounded-full overflow-hidden"><div class="h-full bg-emerald rounded-full" style="width: 88%"></div></div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">PR merge time</span><span class="font-semibold text-emerald">-43%</span></div>
              <div class="h-2 bg-surface-light rounded-full overflow-hidden"><div class="h-full bg-emerald rounded-full" style="width: 43%"></div></div>
            </div>
          </div>
        </div>
      </div>

      {/* 04 - ViDIA */}
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <Terminal title="vidia">
{`$ vidia expert src/auth/login.py
Expert: @jkowalski (score: 0.87)
Last touch: 3 days ago
Bus factor: 1 ⚠
Blast radius: 12 files`}
          </Terminal>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-5xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">04</span>
          <h3 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: var(--font-heading);">ViDIA <span class="text-base font-normal text-text-muted">Developer Intelligence Agent</span></h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            Who knows this code? What breaks if I change it? Why was it built this way? Deterministic intelligence for AI agents via MCP.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="tag bg-blue/10 text-blue border border-blue/20">Open Source</span>
            <span class="tag bg-emerald/10 text-emerald border border-emerald/20">MCP Server</span>
            <span class="tag bg-purple/10 text-purple border border-purple/20">CLI</span>
          </div>
          <div class="flex gap-3">
            <a href="https://github.com/VirtusLab/visdom-developer-intelligence" target="_blank" rel="noopener" class="btn-pill btn-primary text-sm">View on GitHub</a>
            <a href="https://github.com/VirtusLab/visdom-developer-intelligence" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">Docs</a>
          </div>
        </div>
      </div>

      {/* 05 - TraceVault */}
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-5xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">05</span>
          <h3 class="text-2xl font-bold text-text mt-2 mb-4" style="font-family: var(--font-heading);">TraceVault <span class="text-base font-normal text-text-muted">Flight Recorder for AI Development</span></h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            You can't govern what you can't see. TraceVault captures every AI agent interaction - session traces, token usage, tool calls - with cryptographic audit trails and policy enforcement.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="tag bg-blue/10 text-blue border border-blue/20">Open Source</span>
            <span class="tag bg-amber/10 text-amber border border-amber/20">Governance</span>
            <span class="tag bg-purple/10 text-purple border border-purple/20">Compliance</span>
          </div>
          <div class="flex gap-3">
            <a href="https://tracevault.dev/" target="_blank" rel="noopener" class="btn-pill btn-primary text-sm">tracevault.dev</a>
            <a href="https://github.com/softwaremill/tracevault" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">GitHub</a>
          </div>
        </div>
        <div class="surface-card p-8">
          <div class="space-y-4">
            {[
              { icon: '&#x25C9;', name: 'Capture', desc: 'Session traces, token usage, tool calls, secret redaction' },
              { icon: '&#x25C9;', name: 'Enforce', desc: 'Model allowlists, path protection, token budgets' },
              { icon: '&#x25C9;', name: 'Audit', desc: 'Ed25519 signatures, hash-chained records, SOX/PCI-DSS' },
              { icon: '&#x25C9;', name: 'Analyze', desc: 'Cost tracking, model distribution, adoption patterns' },
              { icon: '&#x25C9;', name: 'Code', desc: 'Line-by-line AI attribution via tree-sitter' },
            ].map(p => (
              <div class="flex items-start gap-3">
                <span class="text-emerald mt-0.5 text-sm" set:html={p.icon}></span>
                <div>
                  <span class="text-sm font-semibold text-text">{p.name}</span>
                  <span class="text-xs text-text-muted ml-2">{p.desc}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* 06 - Agent Skills + Reference Architectures (compact row) */}
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card p-8">
          <span class="text-3xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">06</span>
          <h3 class="text-xl font-bold text-text mt-2 mb-3" style="font-family: var(--font-heading);">Agent Skills Library</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Battle-tested skills following the Anthropic Agent Skills spec. IDE-agnostic, community-maintained.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="tag bg-blue/10 text-blue border border-blue/20">Open Source</span>
            <span class="tag bg-emerald/10 text-emerald border border-emerald/20">Anthropic Spec</span>
          </div>
          <a href="https://github.com/VirtusLab/agent-skills" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">Browse on GitHub &rarr;</a>
        </div>
        <div class="card p-8">
          <span class="text-3xl font-extrabold text-surface-light" style="font-family: var(--font-heading);">07</span>
          <h3 class="text-xl font-bold text-text mt-2 mb-3" style="font-family: var(--font-heading);">Reference Architectures</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Full C4 blueprints for agentic systems. Insurance underwriting with human-in-the-loop, 4 reference implementations.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="tag bg-amber/10 text-amber border border-amber/20">Blueprint</span>
            <span class="tag bg-blue/10 text-blue border border-blue/20">Open Source</span>
          </div>
          <a href="https://github.com/VirtusLab/ai-insurance-reference-architecture" target="_blank" rel="noopener" class="btn-pill btn-outline text-sm">Explore Architecture &rarr;</a>
        </div>
      </div>

    </div>
  </div>
</section>
