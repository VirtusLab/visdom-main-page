---
import { SolutionCard as SolutionCardReact } from '@virtuslab/visdom-ui';
import type { SolutionCardTag, SolutionCardCta } from '@virtuslab/visdom-ui';

interface Props {
  title: string;
  subtitle: string;
  problem: string;
  capabilities: string[];
  tags: SolutionCardTag[];
  ctas: SolutionCardCta[];
  metric?: { lines: string[] };
}

const { title, subtitle, problem, capabilities, tags, ctas, metric } = Astro.props;
---
<SolutionCardReact
  title={title}
  subtitle={subtitle}
  problem={problem}
  capabilities={capabilities}
  tags={tags}
  ctas={ctas}
  metric={metric}
  client:load
>
  <slot />
</SolutionCardReact>
