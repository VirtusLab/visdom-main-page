---
// Architecture Flow: scroll-driven, ambient-animated SVG of the Visdom
// AI software-engineering architecture. See docs/architecture-flow.md.
// Edit the data arrays below to add/rename sources, tests, review levels,
// triage branches, or the scroll captions.

const sources = [
  { label: 'Jira', icon: 'jira' },
  { label: 'Git history', icon: 'git' },
  { label: 'Discussions', icon: 'chat' },
  { label: 'Repositories', icon: 'repo' },
  { label: 'Documentation', icon: 'docs' },
  { label: 'Org knowledge', icon: 'org' },
];

// Lucide-style line icons (24x24), drawn via set:html inside the source nodes.
const icons: Record<string, string> = {
  jira: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 7v10M12 7v7M16 7v4"/>',
  git: '<circle cx="12" cy="12" r="3"/><path d="M3 12h6M15 12h6"/>',
  chat: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  repo: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  docs: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M16 13H8M16 17H8M10 9H8"/>',
  org: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
};

const testLayers = [
  'Classic tests',
  'Mutation testing',
  'Architecture testing',
  'Property-based',
];

const reviewLevels = [
  { n: 'L1', label: 'Linting review' },
  { n: 'L2', label: 'Deterministic review' },
  { n: 'L3', label: 'Single-pass LLM' },
  { n: 'L4', label: 'Deep LLM review' },
];

const triageBranches = [
  { tone: 'green', label: 'Green · trivial', sub: 'agent auto-fixes' },
  { tone: 'risk', label: 'High-risk · critical', sub: 'human approval gate' },
];

const captions = [
  { n: '01', t: 'Context Fabric', d: 'We pull Jira, code history, discussions, repos and docs into one place the agent can actually query.' },
  { n: '02', t: 'Preflight context', d: 'Before it writes a line, the agent is loaded with the context the task needs.' },
  { n: '03', t: 'Active context', d: 'As it works, the agent keeps asking the Fabric and getting answers back. Context flows both ways, without stopping.' },
  { n: '04', t: 'Testing layer', d: 'Finished code runs a quality gate: classic, mutation, architecture and property-based tests.' },
  { n: '05', t: 'Multi-level code review', d: 'Four levels, each deeper than the last: linting, deterministic, single-pass LLM, then deep LLM.' },
  { n: '06', t: 'PR & triage', d: 'A pull request sorts every bug by risk. Trivial ones the agent fixes itself; critical ones stop for a human.' },
  { n: '07', t: 'TraceVault', d: 'Every decision, test and review is recorded to TraceVault, one audit trail across the whole system.' },
];

// Ambient particles. Each rides an SVG path (by id) via GSAP MotionPath.
// `stage` ties the particle to the reveal step that owns its path.
// `pause` > 0 turns the dot into a discrete "packet": fade in, travel once,
// fade out, wait, repeat. Without `pause` it loops continuously (the context loop).
const particles = [
  // source wires -> fabric core (stage 0): calm, staggered feed
  ...sources.map((_, i) => ({ path: `af-w${i}`, dur: 3.0, delay: i * 0.55, pause: 1.8, tone: 'ctx', stage: 0 })),
  // preflight, one-way into the agent (stage 1)
  { path: 'af-prerail', dur: 2.0, delay: 0.2, pause: 1.4, tone: 'accent', stage: 1 },
  // active context loop, the centerpiece: continuous, both directions (stage 2)
  { path: 'af-answer', dur: 1.9, delay: 0, tone: 'accent', stage: 2 },
  { path: 'af-answer', dur: 1.9, delay: 0.95, tone: 'accent', stage: 2 },
  { path: 'af-query', dur: 1.9, delay: 0.4, tone: 'accent', stage: 2 },
  { path: 'af-query', dur: 1.9, delay: 1.3, tone: 'accent', stage: 2 },
  // pipeline connectors: one pulse chained left -> right (cycle = dur + pause = 3s)
  { path: 'af-c1', dur: 0.9, delay: 0, pause: 2.1, tone: 'accent', stage: 3 },
  { path: 'af-c2', dur: 0.9, delay: 1.0, pause: 2.1, tone: 'accent', stage: 4 },
  { path: 'af-c3', dur: 0.9, delay: 2.0, pause: 2.1, tone: 'accent', stage: 5 },
  // auto-fix loop back to the agent (stage 5)
  { path: 'af-autofix', dur: 3.2, delay: 0.6, pause: 1.8, tone: 'green', stage: 5 },
  // trace drops into the vault (stage 6)
  ...[0, 1, 2, 3, 4].map((i) => ({ path: `af-t${i}`, dur: 1.4, delay: i * 0.5, pause: 1.8, tone: 'trace', stage: 6 })),
];

// vertical layout helpers
const srcY = (i: number) => 92 + i * 54;
const testY = (i: number) => 170 + i * 46;
const revW = [168, 168, 168, 168];
const revX = [952, 952, 952, 952];
const revIndent = (i: number) => i * 9; // nested look = increasing depth
const revY = (i: number) => 172 + i * 46;
---

<section class="af" id="how-it-works" aria-labelledby="af-title">
  <div class="container af-head">
    <p class="section-label">§ 01 · How a change flows</p>
    <h2 id="af-title" class="section-title">One architecture, end to end</h2>
    <p class="section-subtitle">
      Context Fabric feeds the Coding Agent and keeps answering it as it works. The code then runs
      testing, multi-level review, and risk triage, while TraceVault records every step.
    </p>
  </div>

  <div class="af-track">
    <div class="af-viewport">
      <div class="af-stage">
        <svg viewBox="0 0 1320 552" role="img" aria-labelledby="af-svg-title" class="af-svg" preserveAspectRatio="xMidYMid meet">
          <title id="af-svg-title">Visdom architecture: Context Fabric, Coding Agent, Testing, Code Review, PR triage and TraceVault.</title>

          <defs>
            <marker id="af-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" class="af-arrowhead" />
            </marker>
            <radialGradient id="af-agent-grad" cx="38%" cy="32%" r="78%">
              <stop offset="0%" stop-color="var(--vmm-accent-2)" />
              <stop offset="100%" stop-color="var(--vmm-accent)" />
            </radialGradient>
          </defs>

          <!-- ============ TRACEVAULT (baseplate, spans everything) ============ -->
          <g id="af-tracevault" class="af-group" data-reveal>
            <rect x="44" y="462" width="1232" height="78" rx="18" class="af-vault" />
            <line x1="44" y1="490" x2="1276" y2="490" class="af-vault-rule" />
            <text x="70" y="496" class="af-vault-label">TraceVault</text>
            <text x="70" y="519" class="af-vault-sub">Signed, hash-chained record across every step</text>
            <text x="1252" y="507" text-anchor="end" class="af-vault-tag">observability</text>
            {[331, 600, 814, 1034, 1225].map((x) => (
              <circle cx={x} cy="462" r="3.5" class="af-vault-mark" />
            ))}
          </g>

          <!-- trace-drop paths (stage bottom -> vault) -->
          <path id="af-t0" class="af-trace-path af-reveal" d="M331,322 L331,462" />
          <path id="af-t1" class="af-trace-path af-reveal" d="M600,316 L600,462" />
          <path id="af-t2" class="af-trace-path af-reveal" d="M814,372 L814,462" />
          <path id="af-t3" class="af-trace-path af-reveal" d="M1034,362 L1034,462" />
          <path id="af-t4" class="af-trace-path af-reveal" d="M1225,374 L1225,462" />

          <!-- ============ CONTEXT FABRIC ============ -->
          <g id="af-context" class="af-group" data-reveal>
            <text x="44" y="72" class="af-stage-title">Context Fabric</text>
            {sources.map((s, i) => (
              <g class="af-src">
                <rect x="44" y={srcY(i)} width="214" height="44" rx="11" class="af-card" />
                <g class="af-src-icon" transform={`translate(60,${srcY(i) + 11}) scale(0.9)`} set:html={icons[s.icon]} />
                <text x="96" y={srcY(i) + 27} class="af-card-label">{s.label}</text>
                {/* fan-in: each wire lands on its own port on the fabric edge */}
                <path id={`af-w${i}`} class="af-wire" d={`M258,${srcY(i) + 22} C 268,${srcY(i) + 22} 264,${206 + i * 18} 276,${206 + i * 18}`} />
                <circle cx="276" cy={206 + i * 18} r="2.5" class="af-port" />
              </g>
            ))}
            <!-- fabric core -->
            <rect x="276" y="190" width="112" height="120" rx="20" class="af-core" />
            <text x="332" y="240" text-anchor="middle" class="af-core-label">Context</text>
            <text x="332" y="264" text-anchor="middle" class="af-core-label">Fabric</text>
            <circle cx="332" cy="288" r="3.5" class="af-core-pulse" />
          </g>

          <!-- ============ PREFLIGHT RAIL ============ -->
          <g id="af-preflight" class="af-group" data-reveal>
            <path id="af-prerail" class="af-rail-pre" d="M388,202 L534,206" marker-end="url(#af-arrow)" />
            <text x="458" y="186" text-anchor="middle" class="af-rail-label">Preflight context</text>
          </g>

          <!-- ============ ACTIVE CONTEXT LOOP (centerpiece) ============ -->
          <g id="af-loop" class="af-group" data-reveal>
            <path id="af-answer" class="af-loop-path" d="M390,258 C 436,226 506,228 544,246" marker-end="url(#af-arrow)" />
            <path id="af-query" class="af-loop-path" d="M544,266 C 506,312 436,310 390,282" marker-end="url(#af-arrow)" />
            <text x="468" y="336" text-anchor="middle" class="af-loop-label">Active context</text>
            <text x="468" y="356" text-anchor="middle" class="af-loop-sub">continuous · two-way</text>
          </g>

          <!-- ============ CODING AGENT (always present hub) ============ -->
          <g id="af-agent" class="af-group af-group--base af-reveal">
            <circle cx="600" cy="240" r="74" class="af-agent-ring" />
            <circle cx="600" cy="240" r="62" class="af-agent-core" />
            <text x="600" y="234" text-anchor="middle" class="af-agent-label">Coding</text>
            <text x="600" y="258" text-anchor="middle" class="af-agent-label">Agent</text>
          </g>

          <!-- pipeline connectors (the main spine) -->
          <path id="af-c1" class="af-pipe af-reveal" d="M676,240 L722,240" marker-end="url(#af-arrow)" />
          <path id="af-c2" class="af-pipe af-reveal" d="M904,250 L936,250" marker-end="url(#af-arrow)" />
          <path id="af-c3" class="af-pipe af-reveal" d="M1132,250 C 1142,250 1141,188 1148,186" marker-end="url(#af-arrow)" />

          <!-- ============ TESTING ============ -->
          <g id="af-testing" class="af-group" data-reveal>
            <text x="726" y="150" class="af-stage-title">Testing</text>
            <rect x="724" y="158" width="180" height="212" rx="16" class="af-panel" />
            {testLayers.map((t, i) => (
              <g class="af-test-row">
                <rect x="734" y={testY(i)} width="160" height="36" rx="8" class="af-chip" />
                <text x="814" y={testY(i) + 23} text-anchor="middle" class="af-chip-label">{t}</text>
              </g>
            ))}
          </g>

          <!-- ============ CODE REVIEW (deepening) ============ -->
          <g id="af-review" class="af-group" data-reveal>
            <text x="940" y="150" class="af-stage-title">Code review</text>
            <rect x="940" y="158" width="192" height="212" rx="16" class="af-panel" />
            <text x="1036" y="392" text-anchor="middle" class="af-depth-label">deeper analysis ↓</text>
            {reviewLevels.map((r, i) => (
              <g class={`af-review-row af-depth-${i}`}>
                <rect x={revX[i] + revIndent(i)} y={revY(i)} width={revW[i] - revIndent(i)} height="36" rx="8" class="af-review-bar" />
                <text x={revX[i] + revIndent(i) + 13} y={revY(i) + 23} class="af-review-n">{r.n}</text>
                <text x={revX[i] + revIndent(i) + 36} y={revY(i) + 23} class="af-review-label">{r.label}</text>
              </g>
            ))}
          </g>

          <!-- ============ PR & TRIAGE ============ -->
          <g id="af-triage" class="af-group" data-reveal>
            <text x="1150" y="150" class="af-stage-title">PR &amp; triage</text>
            <rect x="1150" y="158" width="150" height="54" rx="12" class="af-pr" />
            <text x="1225" y="190" text-anchor="middle" class="af-pr-label">Pull Request</text>

            <!-- fork -->
            <path class="af-branch af-branch--green" d="M1225,212 C 1225,232 1190,236 1190,250" />
            <path class="af-branch af-branch--risk" d="M1225,212 C 1225,290 1260,300 1260,314" />

            <g class="af-triage-node af-triage-node--green">
              <rect x="1150" y="250" width="150" height="48" rx="10" class="af-card af-card--green" />
              <text x="1166" y="270" class="af-card-label af-card-label--green">Green · trivial</text>
              <text x="1166" y="288" class="af-card-sub">agent auto-fixes</text>
            </g>
            <g class="af-triage-node af-triage-node--risk">
              <rect x="1150" y="314" width="150" height="48" rx="10" class="af-card af-card--risk" />
              <text x="1190" y="334" class="af-card-label af-card-label--risk">High-risk</text>
              <text x="1190" y="352" class="af-card-sub">human approval gate</text>
              <g class="af-human" transform="translate(1166,330)">
                <circle cx="0" cy="-4" r="5" class="af-human-mark" />
                <path d="M-8,10 a8,9 0 0 1 16,0" class="af-human-mark" />
              </g>
            </g>

            <!-- auto-fix loop back to the agent: leaves the PR top, arcs clear above the panels -->
            <path id="af-autofix" class="af-autofix-path" d="M1225,156 C 1020,36 770,42 608,156" marker-end="url(#af-arrow)" />
            <text x="915" y="46" text-anchor="middle" class="af-autofix-label">auto-fix → back to agent</text>
          </g>

          <!-- ============ AMBIENT PARTICLES (grouped per reveal stage) ============ -->
          <g class="af-particles" aria-hidden="true">
            {[0, 1, 2, 3, 4, 5, 6].map((stage) => (
              <g class="af-pgroup" data-stage={stage}>
                {particles.filter((p) => p.stage === stage).map((p) => (
                  <circle class={`af-particle af-particle--${p.tone}`} r="3.2" cx="-20" cy="-20"
                    data-path={`#${p.path}`} data-dur={p.dur} data-delay={p.delay} data-pause={p.pause ?? 0} />
                ))}
              </g>
            ))}
          </g>
        </svg>
      </div>

      <ol class="af-steps" role="list">
        {captions.map((c, i) => (
          <li class={`af-step${i === 0 ? ' is-active' : ''}`} data-step={i}>
            <span class="af-step-head">
              <span class="af-step-n">{c.n}</span>
              <span class="af-step-t">{c.t}</span>
            </span>
            <span class="af-step-d">{c.d}</span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .af { position: relative; padding: 4rem 0 2rem; }
  .af-head { max-width: 48rem; margin-bottom: 2rem; }
  .af-head .section-subtitle { margin-top: 0.75rem; }

  /* tall track -> sticky viewport for the scrubbed scene */
  .af-track { position: relative; height: 420vh; }
  .af-viewport {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.5rem, 4vh, 3rem);
    max-width: 1320px;
    margin: 0 auto;
    padding: 2rem clamp(20px, 4vw, 56px);
  }

  .af-stage { width: 100%; }
  .af-svg { width: 100%; height: auto; overflow: visible; display: block; }

  /* ---- stage reveal (driven by GSAP; everything visible without JS) ---- */
  .js .af-group[data-reveal],
  .js .af-reveal { opacity: 0; }
  .af-group.is-active :is(.af-core, .af-agent-core, .af-pr, .af-panel) { filter: drop-shadow(0 0 12px var(--vmm-accent)); }

  /* ---- nodes / cards ---- */
  .af-card { fill: var(--card); stroke: var(--color-border); stroke-width: 1.25; }
  .af-card--green { stroke: var(--vmm-accent); }
  .af-card--risk { stroke: var(--color-amber); }
  .af-card-label { fill: var(--color-text); font: 600 16px var(--font-body); }
  .af-card-label--green { fill: var(--color-emerald-dark); font-weight: 700; font-size: 15px; }
  .af-card-label--risk { fill: var(--color-amber); font-weight: 700; font-size: 15px; }
  .af-card-sub { fill: var(--color-text-secondary); font: 500 12.5px var(--font-body); }
  .af-src-icon { fill: none; stroke: var(--vmm-accent); stroke-width: 1.9; stroke-linecap: round; stroke-linejoin: round; }

  .af-stage-title { fill: var(--color-text-secondary); font: 700 14px var(--font-body); letter-spacing: 0.14em; text-transform: uppercase; }

  .af-core { fill: var(--vmm-accent-soft); stroke: var(--vmm-accent); stroke-width: 1.75; }
  .af-core-label { fill: var(--color-text); font: 700 17px var(--font-heading); }
  .af-core-pulse { fill: var(--vmm-accent); animation: af-pulse 2.4s ease-in-out infinite; }

  .af-wire, .af-trace-path {
    fill: none;
    stroke: color-mix(in oklab, var(--vmm-accent) 30%, var(--color-border));
    stroke-width: 1.75;
  }
  .af-trace-path { stroke-dasharray: 3 7; opacity: 0.6; }
  .af-port { fill: var(--vmm-accent); opacity: 0.8; }

  /* the main spine reads as THE flow: solid, accent, thicker */
  .af-pipe { fill: none; stroke: var(--vmm-accent); stroke-width: 2.5; opacity: 0.85; }
  .af-arrowhead { fill: var(--vmm-accent); }

  .af-rail-pre { fill: none; stroke: var(--vmm-accent); stroke-width: 3; }
  .af-rail-label { fill: var(--color-text); font: 600 14px var(--font-body); }

  /* dashes drift along the path direction: constant, legible direction cue */
  .af-loop-path { fill: none; stroke: var(--vmm-accent); stroke-width: 2; stroke-dasharray: 5 5; animation: af-dash 1.1s linear infinite; }
  .af-loop-label { fill: var(--color-emerald-dark); font: 700 15px var(--font-body); }
  .af-loop-sub { fill: var(--color-text-secondary); font: 500 12.5px var(--font-body); }

  .af-agent-ring { fill: none; stroke: var(--vmm-accent); stroke-width: 2; opacity: 0.5; transform-box: fill-box; transform-origin: center; animation: af-ring 2.8s ease-out infinite; }
  .af-agent-core { fill: url(#af-agent-grad); }
  .af-agent-label { fill: var(--primary-foreground, #fff); font: 700 17px var(--font-heading); }

  .af-panel { fill: var(--color-surface); stroke: var(--color-border); stroke-width: 1.25; }
  .af-chip { fill: var(--card); stroke: var(--color-border); stroke-width: 1.25; }
  .af-chip-label { fill: var(--color-text); font: 600 13.5px var(--font-body); }

  .af-review-bar { fill: var(--vmm-accent-soft); stroke: var(--vmm-accent); stroke-width: 1.25; }
  .af-depth-0 .af-review-bar { opacity: 0.5; }
  .af-depth-1 .af-review-bar { opacity: 0.68; }
  .af-depth-2 .af-review-bar { opacity: 0.84; }
  .af-depth-3 .af-review-bar { opacity: 1; }
  .af-review-n { fill: var(--color-emerald-dark); font: 700 12px var(--font-mono); }
  .af-review-label { fill: var(--color-text); font: 600 13px var(--font-body); }
  .af-depth-label { fill: var(--color-text-secondary); font: 600 12.5px var(--font-body); }

  .af-pr { fill: var(--card); stroke: var(--vmm-accent); stroke-width: 1.75; }
  .af-pr-label { fill: var(--color-text); font: 700 15px var(--font-body); }
  .af-branch { fill: none; stroke-width: 2; }
  .af-branch--green { stroke: var(--vmm-accent); }
  .af-branch--risk { stroke: var(--color-amber); }
  .af-human-mark { fill: none; stroke: var(--color-amber); stroke-width: 1.6; }

  .af-autofix-path { fill: none; stroke: var(--vmm-accent); stroke-width: 1.5; stroke-dasharray: 4 6; opacity: 0.6; animation: af-dash 1.4s linear infinite; }
  .af-autofix-label { fill: var(--color-emerald-dark); font: 600 13px var(--font-body); }

  /* ---- vault ---- */
  .af-vault {
    fill: color-mix(in oklab, var(--vmm-accent) 5%, var(--color-surface));
    stroke: color-mix(in oklab, var(--vmm-accent) 25%, var(--color-border));
    stroke-width: 1.5;
  }
  .af-vault-rule { stroke: color-mix(in oklab, var(--vmm-accent) 20%, var(--color-border)); stroke-width: 1; opacity: 0.7; }
  .af-vault-label { fill: var(--color-text); font: 700 19px var(--font-heading); }
  .af-vault-sub { fill: var(--color-text-secondary); font: 500 13.5px var(--font-body); }
  .af-vault-tag { fill: var(--vmm-accent); font: 700 12px var(--font-body); letter-spacing: 0.14em; text-transform: uppercase; }
  .af-vault-mark { fill: var(--vmm-accent); }

  /* dark bg is near-black: the vault needs a stronger tint to read as a layer */
  :global(.dark) .af-vault {
    fill: color-mix(in oklab, var(--vmm-accent) 10%, var(--color-surface));
    stroke: color-mix(in oklab, var(--vmm-accent) 45%, var(--color-border));
  }

  /* ---- particles ---- */
  .af-particle { fill: var(--vmm-accent); }
  .af-particle--green { fill: var(--vmm-accent); }
  .af-particle--risk { fill: var(--color-amber); }
  .af-particle--trace { fill: var(--color-text-muted); r: 2.4; }
  .af-particle--ctx { fill: var(--vmm-accent-2); }

  /* ---- captions: bottom stepper, shared crossfading description ---- */
  .af-steps {
    list-style: none;
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 0 4.2em;
    position: relative;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }
  .af-step {
    padding: 0.9rem 16px 1.1rem;
    border-top: 2px solid var(--color-border);
    opacity: 0.5;
    transition: opacity 0.3s ease, border-color 0.3s ease;
  }
  .af-step.is-active { opacity: 1; border-top-color: var(--vmm-accent); }
  .af-step-head { display: flex; flex-direction: column; gap: 3px; }
  .af-step-n { font: 700 12px var(--font-mono); color: var(--vmm-accent); }
  .af-step-t { font: 600 15px var(--font-heading); color: var(--color-text); line-height: 1.25; }

  /* description: all share one area at the bottom of the row, only active shows */
  .af-step-d {
    position: absolute;
    left: 0;
    bottom: 0.3em;
    width: min(64ch, 100%);
    font: 400 clamp(1rem, 1.35vw, 1.2rem) var(--font-body);
    line-height: 1.55;
    color: var(--color-text-secondary);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }
  .af-step.is-active .af-step-d { opacity: 1; transform: none; }

  @keyframes af-pulse { 0%, 100% { opacity: 1; r: 3.5; } 50% { opacity: 0.4; r: 6; } }
  @keyframes af-ring { 0% { opacity: 0.5; transform: scale(1); } 100% { opacity: 0; transform: scale(1.18); } }
  @keyframes af-dash { to { stroke-dashoffset: -20; } }

  /* ---- responsive: no pin, stack captions, static reveal ---- */
  @media (max-width: 900px) {
    .af-track { height: auto; }
    .af-viewport { position: static; min-height: 0; gap: 1.5rem; }
    .js .af-group[data-reveal],
    .js .af-reveal { opacity: 1; }

    /* keep the wide diagram legible: swipe horizontally */
    .af-stage { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .af-svg { min-width: 960px; }

    .af-steps { grid-template-columns: 1fr; padding-bottom: 0; }
    .af-step { opacity: 1; }
    .af-step-d { position: static; opacity: 1; transform: none; width: auto; margin-top: 0.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .js .af-group[data-reveal],
    .js .af-reveal { opacity: 1; }
    .af-core-pulse, .af-agent-ring, .af-loop-path, .af-autofix-path { animation: none; }
    .af-particle { display: none; }
    .af-step { opacity: 1; }
    /* no scrub: stack descriptions so they do not overlap */
    .af-steps { padding-bottom: 0; }
    .af-step-d { position: static; opacity: 1; transform: none; width: auto; margin-top: 0.5rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';

  gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

  const root = document.querySelector('.af');
  if (root) {
    document.documentElement.classList.add('js');

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const compact = window.matchMedia('(max-width: 900px)').matches;

    const groups = ['af-context', 'af-preflight', 'af-loop', 'af-testing', 'af-review', 'af-triage', 'af-tracevault']
      .map((id) => document.getElementById(id));
    const captions = Array.from(root.querySelectorAll('.af-step'));

    // elements revealed at each scroll step (stage group + its connectors/traces)
    const reveal = [
      ['#af-context'],
      ['#af-preflight', '#af-agent'],
      ['#af-loop'],
      ['#af-testing', '#af-c1'],
      ['#af-review', '#af-c2'],
      ['#af-triage', '#af-c3'],
      ['#af-tracevault', '#af-t0', '#af-t1', '#af-t2', '#af-t3', '#af-t4'],
    ].map((sels) => sels.flatMap((s) => Array.from(document.querySelectorAll(s))));
    const allTargets = reveal.flat();

    // ---- ambient particle motion (always on unless reduced motion) ----
    // pause > 0: discrete packet (fade in, travel once, fade out, wait, repeat)
    // pause = 0: continuous orbit (the active-context loop)
    if (!reduce) {
      root.querySelectorAll('.af-particle').forEach((p) => {
        const sel = p.getAttribute('data-path');
        const path = sel && document.querySelector(sel);
        if (!path) return;
        const dur = parseFloat(p.getAttribute('data-dur') || '2');
        const delay = parseFloat(p.getAttribute('data-delay') || '0');
        const pause = parseFloat(p.getAttribute('data-pause') || '0');
        const motion = { motionPath: { path, align: path, alignOrigin: [0.5, 0.5] } };
        if (pause > 0) {
          const t = gsap.timeline({ repeat: -1, repeatDelay: pause, delay });
          t.fromTo(p, { opacity: 0 }, { opacity: 1, duration: 0.2, ease: 'none' }, 0)
            .to(p, { ...motion, duration: dur, ease: 'power1.inOut' }, 0)
            .to(p, { opacity: 0, duration: 0.25, ease: 'none' }, dur - 0.25);
        } else {
          gsap.to(p, { ...motion, duration: dur, delay, repeat: -1, ease: 'none' });
        }
      });
    }

    const setActive = (idx) => {
      groups.forEach((g, i) => g && g.classList.toggle('is-active', i === idx));
      captions.forEach((c, i) => c.classList.toggle('is-active', i === idx));
    };

    if (reduce || compact) {
      // static: everything revealed, no scrub
      gsap.set(allTargets, { opacity: 1, y: 0 });
      gsap.set('.af-pgroup', { opacity: 1 });
      captions.forEach((c) => c.classList.add('is-active'));
    } else {
      const steps = reveal.length;
      // start fully hidden, then unveil one cluster per scroll step.
      // particles are gated via their stage GROUP, so the per-dot ambient
      // tweens never fight the scroll tween over the same property.
      gsap.set(allTargets, { opacity: 0, y: 14 });
      gsap.set('.af-pgroup', { opacity: 0 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '.af-track',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          onUpdate: (self) => setActive(Math.min(steps - 1, Math.floor(self.progress * steps))),
        },
      });

      reveal.forEach((els, i) => {
        tl.to(els, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, i);
        tl.to(`.af-pgroup[data-stage="${i}"]`, { opacity: 1, duration: 0.5 }, i + 0.25);
      });
      // tail room so the last stage fully lands before the scroll ends
      tl.to({}, { duration: 0.8 });

      setActive(0);
    }

    ScrollTrigger.refresh();
  }
</script>
