<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';

  gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

  const root = document.querySelector('.af');
  if (root) {
    document.documentElement.classList.add('js');

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const compact = window.matchMedia('(max-width: 900px)').matches;

    const groups = ['af-context', 'af-preflight', 'af-loop', 'af-testing', 'af-review', 'af-triage', 'af-tracevault', 'af-ship']
      .map((id) => document.getElementById(id));
    const captions = Array.from(root.querySelectorAll('.af-step'));

    // elements revealed at each scroll step (stage group + its connectors/traces)
    const reveal = [
      ['#af-context'],
      ['#af-preflight', '#af-agent'],
      ['#af-loop'],
      ['#af-testing', '#af-c1g'],
      ['#af-pr-env', '#af-review', '#af-c2g', '#af-tap-review'],
      ['#af-triage', '#af-c3g'],
      ['#af-tracevault', '#af-t0', '#af-t1', '#af-t2', '#af-t3'],
      ['#af-ship', '#af-c4g', '#af-t4', '#af-approved'],
    ].map((sels) => sels.flatMap((s) => Array.from(document.querySelectorAll(s))));
    const allTargets = reveal.flat();

    // HUD reticle target boxes per stage (viewBox coordinates)
    const RETICLE = [
      { x: 36, y: 118, w: 1128, h: 82 },
      { x: 44, y: 196, w: 146, h: 84 },
      { x: 162, y: 186, w: 172, h: 112 },
      { x: 266, y: 236, w: 206, h: 232 },
      { x: 516, y: 236, w: 218, h: 232 },
      { x: 778, y: 236, w: 194, h: 290 },
      { x: 36, y: 530, w: 1128, h: 84 },
      { x: 988, y: 256, w: 176, h: 112 },
    ];
    const corners = {
      tl: document.getElementById('af-ret-tl'),
      tr: document.getElementById('af-ret-tr'),
      bl: document.getElementById('af-ret-bl'),
      br: document.getElementById('af-ret-br'),
    };
    const moveReticle = (idx, instant = false) => {
      const r = RETICLE[idx];
      if (!r || !corners.tl) return;
      const pos = {
        tl: { x: r.x, y: r.y, scaleX: 1, scaleY: 1 },
        tr: { x: r.x + r.w, y: r.y, scaleX: -1, scaleY: 1 },
        bl: { x: r.x, y: r.y + r.h, scaleX: 1, scaleY: -1 },
        br: { x: r.x + r.w, y: r.y + r.h, scaleX: -1, scaleY: -1 },
      };
      Object.entries(pos).forEach(([k, p]) => {
        gsap.to(corners[k], { ...p, opacity: 1, duration: instant ? 0 : 0.55, ease: 'power3.out' });
      });
    };

    // ---- ambient particle motion (always on unless reduced motion) ----
    // pause > 0: discrete packet (fade in, travel once, fade out, wait, repeat)
    // pause = 0: continuous orbit (the active-context loop)
    if (!reduce) {
      root.querySelectorAll('.af-particle').forEach((p) => {
        const sel = p.getAttribute('data-path');
        const path = sel && document.querySelector(sel);
        if (!path) return;
        const dur = parseFloat(p.getAttribute('data-dur') || '2');
        const delay = parseFloat(p.getAttribute('data-delay') || '0');
        const pause = parseFloat(p.getAttribute('data-pause') || '0');
        const motion = { motionPath: { path, align: path, alignOrigin: [0.5, 0.5] } };
        if (pause > 0) {
          const t = gsap.timeline({ repeat: -1, repeatDelay: pause, delay });
          t.fromTo(p, { opacity: 0 }, { opacity: 1, duration: 0.2, ease: 'none' }, 0)
            .to(p, { ...motion, duration: dur, ease: 'power1.inOut' }, 0)
            .to(p, { opacity: 0, duration: 0.25, ease: 'none' }, dur - 0.25);
        } else {
          gsap.to(p, { ...motion, duration: dur, delay, repeat: -1, ease: 'none' });
        }
      });
    }

    let lastIdx = -1;
    const setActive = (idx) => {
      if (idx === lastIdx) return;
      lastIdx = idx;
      groups.forEach((g, i) => g && g.classList.toggle('is-active', i === idx));
      captions.forEach((c, i) => c.classList.toggle('is-active', i === idx));
      moveReticle(idx);
    };

    if (reduce || compact) {
      // static: everything revealed, no scrub, no reticle
      gsap.set(allTargets, { opacity: 1, y: 0 });
      gsap.set('.af-pgroup', { opacity: 1 });
      gsap.set('#af-reticle', { display: 'none' });
      captions.forEach((c) => c.classList.add('is-active'));
      // static mode has no scrub to jump to, take the inert buttons out of the tab order
      root.querySelectorAll('.af-step-btn').forEach((b) => b.setAttribute('tabindex', '-1'));
    } else {
      const steps = reveal.length;
      // unveil one cluster per scroll step. stage one is on stage from the
      // first frame: an empty canvas under an active step 01 reads as broken.
      // particles are gated via their stage GROUP, so the per-dot ambient
      // tweens never fight the scroll tween over the same property.
      gsap.set(allTargets, { opacity: 0, y: 14 });
      gsap.set(reveal[0], { opacity: 1, y: 0 });
      gsap.set('.af-pgroup', { opacity: 0 });
      gsap.set('.af-pgroup[data-stage="0"]', { opacity: 1 });
      // gates cascade in one by one inside their stage
      const cascades = {
        3: '#af-testing .af-test-row',
        4: '#af-review .af-review-row',
        5: '#af-triage .af-triage-node',
      };
      Object.values(cascades).forEach((sel) => gsap.set(sel, { opacity: 0, y: 10 }));

      // the HUD frame stays hidden until the reader actually reaches the
      // pinned diagram, a highlight before any scrolling reads as noise
      gsap.set('#af-reticle', { opacity: 0 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '.af-track',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          onUpdate: (self) => setActive(Math.min(steps - 1, Math.floor(self.progress * steps))),
          onToggle: (self) => gsap.to('#af-reticle', { opacity: self.isActive ? 1 : 0, duration: 0.4 }),
        },
      });

      reveal.forEach((els, i) => {
        if (i === 0) return; // already visible at the start
        tl.to(els, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, i);
        if (cascades[i]) {
          tl.to(cascades[i], { opacity: 1, y: 0, duration: 0.35, stagger: 0.18, ease: 'power2.out' }, i + 0.12);
        }
        const grp = document.querySelector(`.af-pgroup[data-stage="${i}"]`);
        if (grp) tl.to(grp, { opacity: 1, duration: 0.5 }, i + 0.25);
      });
      // tail room so the last stage fully lands before the scroll ends
      tl.to({}, { duration: 0.8 });

      // clicking a step scrolls the page to that stage of the scrub
      captions.forEach((c, i) => {
        const btn = c.querySelector('.af-step-btn');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const st = tl.scrollTrigger;
          const target = st.start + (st.end - st.start) * ((i + 0.5) / steps);
          window.scrollTo({ top: target, behavior: 'smooth' });
        });
      });

      setActive(0);
      moveReticle(0, true);
      // page loaded mid-track (refresh while inside the section): show the frame right away
      if (tl.scrollTrigger && tl.scrollTrigger.isActive) gsap.set('#af-reticle', { opacity: 1 });
    }

    ScrollTrigger.refresh();
  }
</script>
