---
// Architecture Flow: scroll-driven, ambient-animated SVG of the Visdom
// AI software-engineering architecture. See docs/architecture-flow.md.
// Edit the data arrays below to add/rename sources, tests, review levels,
// triage branches, or the scroll captions.

const sources = [
  { label: 'Jira', icon: 'jira' },
  { label: 'Git history', icon: 'git' },
  { label: 'Discussions', icon: 'chat' },
  { label: 'Repositories', icon: 'repo' },
  { label: 'Documentation', icon: 'docs' },
  { label: 'Org knowledge', icon: 'org' },
];

// Lucide-style line icons (24x24), drawn via set:html inside the source nodes.
const icons: Record<string, string> = {
  jira: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 7v10M12 7v7M16 7v4"/>',
  git: '<circle cx="12" cy="12" r="3"/><path d="M3 12h6M15 12h6"/>',
  chat: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  repo: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  docs: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M16 13H8M16 17H8M10 9H8"/>',
  org: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
  // module header + accent icons
  layers: '<path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
  flask: '<path d="M9 3h6M10 3v5L5 16a3 3 0 0 0 2.6 4.5h8.8A3 3 0 0 0 19 16l-5-8V3"/><path d="M7.5 14h9"/>',
  eye: '<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"/><circle cx="12" cy="12" r="3"/>',
  pr: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><path d="M6 9v6"/><path d="M13 6h2a3 3 0 0 1 3 3v6"/>',
  link: '<path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/>',
  spark: '<path d="M12 3l1.9 5.8a2 2 0 0 0 1.3 1.3L21 12l-5.8 1.9a2 2 0 0 0-1.3 1.3L12 21l-1.9-5.8a2 2 0 0 0-1.3-1.3L3 12l5.8-1.9a2 2 0 0 0 1.3-1.3L12 3z"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  funnel: '<path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
};

const testLayers = [
  'Classic tests',
  'Architecture testing',
  'Property-based',
  'Mutation testing',
];

const reviewLevels = [
  { n: 'L1', label: 'Linting review' },
  { n: 'L2', label: 'Deterministic review' },
  { n: 'L3', label: 'Single-pass LLM' },
  { n: 'L4', label: 'Deep LLM review' },
];

const triageBranches = [
  { tone: 'green', label: 'Green · trivial', sub: 'agent auto-fixes' },
  { tone: 'risk', label: 'High-risk · critical', sub: 'human approval gate' },
];

const captions = [
  { n: '01', t: 'Context Fabric', d: 'Jira tickets, git history, old debates, buried docs: everything your team knows, woven into one fabric the agent can actually ask.' },
  { n: '02', t: 'Preflight context', d: 'No cold starts. Before the first line of code, the agent already knows the task, the owners, and the landmines.' },
  { n: '03', t: 'Active context', d: 'Who owns this? What breaks if it changes? The agent keeps asking, the Fabric keeps answering. Context never stops flowing.' },
  { n: '04', t: 'Testing layer', d: 'Agents love tests that pass. These gates do not care: architecture rules, property-based inputs and mutation testing expose what green CI hides.' },
  { n: '05', t: 'Code review · VCR', d: 'VCR reads every PR before any human does: lint, deterministic checks, then LLM passes that know how your repo is actually written.' },
  { n: '06', t: 'Triage', d: 'Not every bug deserves a meeting. The gate scores path, diff and coverage: trivial ones the agent fixes on the spot, the risky ones stop and wait for a human.' },
  { n: '07', t: 'TraceVault', d: 'Every prompt, decision and test lands in a signed, hash-chained ledger. When the auditor asks, the answer already exists.' },
  { n: '08', t: 'Ship to production', d: 'All gates green. The change rolls out with receipts: tested, reviewed, traced. Ship it and enjoy the moment.' },
];

// Ambient particles. Each rides an SVG path (by id) via GSAP MotionPath.
// `stage` ties the particle to the reveal step that owns its path.
// `pause` > 0 turns the dot into a discrete "packet": fade in, travel once,
// fade out, wait, repeat. Without `pause` it loops continuously (the context loop).
// Discrete "packet" dots remain only where they read as items (knowledge in,
// traces down). Lines that carry flow use CSS light streaks instead.
const particles = [
  // knowledge drops from each source into the fabric bar (stage 0)
  ...sources.map((_, i) => ({ path: `af-w${i}`, dur: 1.0, delay: i * 0.4, pause: 1.6, tone: 'ctx', stage: 0 })),
  // code review taps the fabric for conventions and ownership (stage 4)
  { path: 'af-tapr', dur: 1.1, delay: 0.2, pause: 1.5, tone: 'ctx', stage: 4 },
  { path: 'af-tapr', dur: 1.1, delay: 1.6, pause: 1.5, tone: 'ctx', stage: 4 },
  // traces drop into the vault (stage 6), production drops its own (stage 7)
  { path: 'af-t0', dur: 1.2, delay: 0, pause: 1.8, tone: 'trace', stage: 6 },
  ...[1, 2, 3].map((i) => ({ path: `af-t${i}`, dur: 0.7, delay: i * 0.5, pause: 1.8, tone: 'trace', stage: 6 })),
  { path: 'af-t4', dur: 1.4, delay: 0.4, pause: 2.0, tone: 'trace', stage: 7 },
];
const particleStages = [...new Set(particles.map((p) => p.stage))];

// layout helpers: sources run horizontally, fabric is a bar like the vault
const srcX = (i: number) => 44 + i * 188;
const srcCX = (i: number) => 130 + i * 188;
const testY = (i: number) => 284 + i * 40;
const revW = [178, 178, 178, 178];
const revX = [536, 536, 536, 536];
const revY = (i: number) => 284 + i * 40;
---

<section class="af" id="how-it-works" aria-labelledby="af-title">
  <div class="container af-head">
    <p class="section-label">How a change flows</p>
    <h2 id="af-title" class="section-title">One architecture, end to end</h2>
    <p class="section-subtitle">
      Context Fabric feeds the agent system, code, organizational and historical context over MCP, both ways, continuously.
      The change then clears <a href="https://virtuslab.github.io/visdom-testing/" target="_blank" rel="noopener">testing</a>,
      <a href="https://virtuslab.github.io/visdom-code-review/" target="_blank" rel="noopener">multi-level review</a> and risk triage;
      <a href="https://virtuslab.github.io/visdom-governance/" target="_blank" rel="noopener">TraceVault</a> signs every step.
    </p>
  </div>

  <div class="af-track">
    <div class="af-viewport">
      <div class="af-stage">
        <svg viewBox="0 0 1200 640" role="img" aria-labelledby="af-svg-title" class="af-svg" preserveAspectRatio="xMidYMid meet">
          <title id="af-svg-title">Visdom architecture: Context Fabric, Coding Agent, Testing, Code Review, PR triage and TraceVault.</title>

          <defs>
            <!-- sharp dart: long tip, concave tail -->
            <marker id="af-arrow" viewBox="0 0 12 9" refX="11" refY="4.5" markerWidth="9" markerHeight="6.75" orient="auto-start-reverse">
              <path d="M0,0.5 L12,4.5 L0,8.5 L3.2,4.5 Z" class="af-arrowhead" />
            </marker>
            <marker id="af-arrow-amber" viewBox="0 0 12 9" refX="11" refY="4.5" markerWidth="9" markerHeight="6.75" orient="auto-start-reverse">
              <path d="M0,0.5 L12,4.5 L0,8.5 L3.2,4.5 Z" class="af-arrowhead--amber" />
            </marker>
            <radialGradient id="af-agent-grad" cx="38%" cy="32%" r="78%">
              <stop offset="0%" stop-color="var(--vmm-accent-2)" />
              <stop offset="100%" stop-color="var(--vmm-accent)" />
            </radialGradient>
            <linearGradient id="af-depth-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--vmm-accent)" stop-opacity="0.12" />
              <stop offset="100%" stop-color="var(--vmm-accent)" stop-opacity="0.9" />
            </linearGradient>
            <pattern id="af-grid" width="26" height="26" patternUnits="userSpaceOnUse">
              <circle cx="1" cy="1" r="1" class="af-grid-dot" />
            </pattern>
          </defs>

          <!-- blueprint substrate: dot grid + corner registration marks -->
          <rect x="36" y="40" width="1128" height="572" fill="url(#af-grid)" class="af-bp" aria-hidden="true" />
          <g class="af-fid" aria-hidden="true">
            {[[40, 44], [1160, 44], [40, 618], [1160, 618]].map(([x, y]) => (
              <path d={`M${x - 5},${y} H${x + 5} M${x},${y - 5} V${y + 5}`} />
            ))}
          </g>

          <!-- ============ TRACEVAULT (baseplate, spans everything) ============ -->
          <g id="af-tracevault" class="af-group" data-reveal>
            <rect x="44" y="538" width="1112" height="68" rx="18" class="af-vault" />
            <line x1="60" y1="539.5" x2="1140" y2="539.5" class="af-sheen" />
            <g class="af-vault-icon" transform="translate(64,555) scale(0.8)" set:html={icons.link} />
            <text x="94" y="565" class="af-vault-label">TraceVault</text>
            <text x="94" y="588" class="af-vault-sub">Signed, hash-chained record across every step</text>
            {/* hash-chain motif: linked blocks, append-only */}
            <g class="af-chain" aria-hidden="true">
              {[940, 968, 996, 1024].map((x, i) => (
                <>
                  <rect x={x} y="558" width="14" height="14" rx="3" class={`af-chain-block${i === 3 ? ' af-chain-block--head' : ''}`} />
                  {i < 3 && <line x1={x + 14} y1="565" x2={x + 28} y2="565" class="af-chain-link" />}
                </>
              ))}
            </g>
            <text x="1132" y="570" text-anchor="end" class="af-vault-tag">Ed25519</text>
            {[150, 369, 625, 875, 1076].map((x) => (
              <circle cx={x} cy="538" r="3.5" class="af-vault-mark" />
            ))}
          </g>

          <!-- trace-drop paths (stage bottom -> vault) -->
          <path id="af-t0" class="af-trace-path af-reveal" d="M150,428 L150,538" />
          <path id="af-t1" class="af-trace-path af-reveal" d="M369,466 L369,538" />
          <path id="af-t2" class="af-trace-path af-reveal" d="M625,466 L625,538" />
          <path id="af-t3" class="af-trace-path af-reveal" d="M875,522 L875,538" />
          <path id="af-t4" class="af-trace-path af-reveal" d="M1076,366 L1076,538" />

          <!-- ============ CONTEXT FABRIC: sources row + cross-cutting bar ============ -->
          <g id="af-context" class="af-group" data-reveal>
            {sources.map((s, i) => (
              <g class="af-src">
                <rect x={srcX(i)} y="56" width="172" height="42" rx="11" class="af-card" />
                <g class="af-src-icon" transform={`translate(${srcX(i) + 14},66) scale(0.85)`} set:html={icons[s.icon]} />
                <text x={srcX(i) + 46} y="82" class="af-card-label">{s.label}</text>
                <path id={`af-w${i}`} class="af-wire" d={`M${srcCX(i)},98 L${srcCX(i)},126`} />
                <circle cx={srcCX(i)} cy="126" r="2.5" class="af-port" />
              </g>
            ))}
            <!-- the fabric bar: cross-cutting, like the vault below -->
            <rect x="44" y="126" width="1112" height="66" rx="18" class="af-vault af-fabricbar" />
            <line x1="60" y1="127.5" x2="1140" y2="127.5" class="af-sheen" />
            <g class="af-vault-icon" transform="translate(64,149) scale(0.8)" set:html={icons.layers} />
            <text x="94" y="166" class="af-vault-label">Context Fabric</text>
            <text x="1132" y="163" text-anchor="end" class="af-vault-tag">queried by every stage</text>
          </g>

          <!-- ============ PREFLIGHT RAIL (fabric -> agent, once) ============ -->
          <g id="af-preflight" class="af-group" data-reveal>
            <path id="af-prerail" class="af-rail-pre" d="M64,192 L64,312 Q64,330 78,330" marker-end="url(#af-arrow)" />
            <path class="af-streak" pathLength="100" d="M64,192 L64,312 Q64,330 78,330" style="animation-duration:2.6s" />
            <text x="76" y="230" class="af-rail-label">Preflight</text>
            <text x="76" y="246" class="af-rail-label">context</text>
          </g>

          <!-- ============ ACTIVE CONTEXT LOOP (fabric <-> agent, continuous) ============ -->
          <g id="af-loop" class="af-group" data-reveal>
            <path id="af-answer" class="af-loop-path" d="M160,192 C 168,214 168,240 162,262" marker-end="url(#af-arrow)" />
            <path id="af-query" class="af-loop-path" d="M180,268 C 188,244 188,214 182,196" marker-end="url(#af-arrow)" />
            <path class="af-streak" pathLength="100" d="M160,192 C 168,214 168,240 162,262" style="animation-duration:1.8s" />
            <path class="af-streak" pathLength="100" d="M180,268 C 188,244 188,214 182,196" style="animation-duration:1.8s;animation-delay:-0.9s" />
            <text x="208" y="224" class="af-loop-label">Active</text>
            <text x="208" y="242" class="af-loop-label">context</text>
          </g>

          <!-- ============ CODING AGENT (always present hub) ============ -->
          <g id="af-agent" class="af-group af-group--base af-reveal">
            <circle cx="150" cy="330" r="66" class="af-agent-ring" />
            <circle cx="150" cy="330" r="59" class="af-agent-ticks" />
            <circle cx="150" cy="330" r="51" class="af-agent-core" />
            <g class="af-agent-spark" transform="translate(142,293) scale(0.68)" set:html={icons.spark} />
            <text x="150" y="334" text-anchor="middle" class="af-agent-label">Coding</text>
            <text x="150" y="354" text-anchor="middle" class="af-agent-label">Agent</text>
            <!-- the agent runs contained: Sandcat sandbox tag -->
            <rect x="97" y="404" width="106" height="18" rx="9" class="af-sandbox-tag" />
            <text x="150" y="416.5" text-anchor="middle" class="af-sandbox-label">Sandcat sandbox</text>
          </g>

          <!-- pipeline connectors (the main spine) -->
          <g id="af-c1g" class="af-reveal">
            <path id="af-c1" class="af-pipe" d="M214,312 L266,312" marker-end="url(#af-arrow)" />
            <path class="af-streak af-streak--pipe" pathLength="100" d="M214,312 L266,312" style="animation-duration:2.4s" />
          </g>
          <g id="af-c2g" class="af-reveal">
            <path id="af-c2" class="af-pipe" d="M464,312 L518,312" marker-end="url(#af-arrow)" />
            <path class="af-streak af-streak--pipe" pathLength="100" d="M464,312 L518,312" style="animation-duration:2.4s;animation-delay:0.6s" />
          </g>
          <g id="af-c3g" class="af-reveal">
            <path id="af-c3" class="af-pipe" d="M726,312 L780,312" marker-end="url(#af-arrow)" />
            <path class="af-streak af-streak--pipe" pathLength="100" d="M726,312 L780,312" style="animation-duration:2.4s;animation-delay:1.2s" />
          </g>
          <g id="af-c4g" class="af-reveal">
            <path id="af-c4" class="af-pipe" d="M964,312 L990,312" marker-end="url(#af-arrow)" />
            <path class="af-streak af-streak--pipe" pathLength="100" d="M964,312 L990,312" style="animation-duration:2.4s;animation-delay:1.8s" />
          </g>

          <!-- ============ TESTING ============ -->
          <g id="af-testing" class="af-group af-module" data-reveal>
            <rect x="274" y="244" width="190" height="216" rx="16" class="af-panel" />
            <line x1="290" y1="245.5" x2="448" y2="245.5" class="af-sheen" />
            <rect x="280" y="250" width="178" height="26" rx="8" class="af-mhead" />
            <g class="af-mhead-icon" transform="translate(290,255) scale(0.66)" set:html={icons.flask} />
            <text x="312" y="268" class="af-mhead-label">Testing</text>
            {testLayers.map((t, i) => (
              <g class="af-test-row">
                <rect x="286" y={testY(i)} width="166" height="34" rx="8" class="af-chip" />
                <text x="369" y={testY(i) + 22} text-anchor="middle" class="af-chip-label">{t}</text>
              </g>
            ))}
          </g>

          <!-- code review taps the fabric for conventions and ownership -->
          <g id="af-tap-review" class="af-reveal">
            <path id="af-tapr" class="af-trace-path" d="M665,192 L665,240" marker-end="url(#af-arrow)" />
          </g>

          <!-- the pull request: a soft envelope, review and triage happen inside it -->
          <g id="af-pr-env" class="af-reveal">
            <rect x="508" y="214" width="470" height="248" rx="20" class="af-prenv" />
            <g class="af-prenv-icon" transform="translate(524,221) scale(0.6)" set:html={icons.pr} />
            <text x="544" y="234" class="af-prenv-label">Pull Request</text>
          </g>

          <!-- ============ CODE REVIEW (deepening) ============ -->
          <g id="af-review" class="af-group af-module" data-reveal>
            <rect x="524" y="244" width="202" height="216" rx="16" class="af-panel" />
            <line x1="540" y1="245.5" x2="710" y2="245.5" class="af-sheen" />
            <rect x="530" y="250" width="190" height="26" rx="8" class="af-mhead" />
            <g class="af-mhead-icon" transform="translate(540,255) scale(0.66)" set:html={icons.eye} />
            <text x="562" y="268" class="af-mhead-label">Code review · VCR</text>
            {reviewLevels.map((r, i) => (
              <g class={`af-review-row af-depth-${i}`}>
                <rect x={revX[i]} y={revY(i)} width={revW[i]} height="34" rx="8" class="af-review-bar" />
                <text x={revX[i] + 13} y={revY(i) + 22} class="af-review-n">{r.n}</text>
                <text x={revX[i] + 36} y={revY(i) + 22} class="af-review-label">{r.label}</text>
              </g>
            ))}
          </g>

          <!-- ============ TRIAGE (its own block: it owns the gating) ============ -->
          <g id="af-triage" class="af-group af-module" data-reveal>
            <rect x="786" y="244" width="178" height="104" rx="16" class="af-panel" />
            <line x1="802" y1="245.5" x2="948" y2="245.5" class="af-sheen" />
            <rect x="792" y="250" width="166" height="26" rx="8" class="af-mhead" />
            <g class="af-mhead-icon" transform="translate(802,255) scale(0.66)" set:html={icons.funnel} />
            <text x="824" y="268" class="af-mhead-label">Triage</text>

            <rect x="798" y="291" width="154" height="42" rx="10" class="af-pr" />
            <text x="875" y="317" text-anchor="middle" class="af-pr-label">Risk gate</text>

            <!-- fork below the panel: trivial loops back, risk stops at the human gate.
                 the risk drop, the gate and its trace share one axis: PR -> gate -> vault -->
            <path class="af-branch af-branch--risk" d="M875,350 L875,464" marker-end="url(#af-arrow-amber)" />
            <g class="af-triage-node af-triage-node--green">
              <path id="af-autofix" class="af-autofix-path" d="M840,350 C 840,440 790,498 700,498 L320,498 C 252,498 206,442 200,374" marker-end="url(#af-arrow)" />
              <path class="af-streak af-streak--soft" pathLength="100" d="M840,350 C 840,440 790,498 700,498 L320,498 C 252,498 206,442 200,374" style="animation-duration:3.6s" />
              <text x="470" y="488" text-anchor="middle" class="af-autofix-label">green · trivial: auto-fix → back to agent</text>
            </g>
            <g class="af-triage-node af-triage-node--risk">
              <rect x="798" y="470" width="154" height="46" rx="10" class="af-card af-card--risk" />
              <text x="838" y="490" class="af-card-label af-card-label--risk">High-risk</text>
              <text x="838" y="507" class="af-card-sub">human approval</text>
              <g class="af-human" transform="translate(818,488)">
                <circle cx="0" cy="-4" r="5" class="af-human-mark" />
                <path d="M-8,10 a8,9 0 0 1 16,0" class="af-human-mark" />
              </g>
              <!-- approved: the human waves it through, orthogonal elbow up to production.
                   revealed with the ship stage so the arrow never points at empty space -->
              <g id="af-approved">
                <path class="af-branch af-branch--risk" d="M952,493 L1022,493 Q1038,493 1038,477 L1038,368" marker-end="url(#af-arrow-amber)" />
                <text x="962" y="485" class="af-approved-label">approved</text>
              </g>
            </g>
          </g>

          <!-- ============ SHIP TO PRODUCTION (the joyful finale, end of the line) ============ -->
          <g id="af-ship" class="af-group" data-reveal>
            <rect x="996" y="264" width="160" height="96" rx="16" class="af-ship-box" />
            <line x1="1012" y1="265.5" x2="1140" y2="265.5" class="af-sheen" />
            <g class="af-ship-icon" transform="translate(1014,299) scale(1.15)" set:html={icons.rocket} />
            <text x="1052" y="318" class="af-ship-label">Production</text>
            <!-- passed seal -->
            <circle cx="1148" cy="272" r="11" class="af-seal" />
            <g class="af-seal-check" transform="translate(1140,264) scale(0.66)" set:html={icons.check} />
            <!-- confetti: the only multi-colour moment in the whole diagram -->
            <g class="af-confetti" aria-hidden="true">
              {[
                { x: 1004, y: 250, c: 1, d: 0 },
                { x: 1028, y: 244, c: 2, d: 0.3 },
