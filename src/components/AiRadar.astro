---
const stats = [
  { value: '777', label: 'signals' },
  { value: '17', label: 'areas' },
  { value: '354', label: 'discoveries' },
  { value: '251', label: 'releases' },
];
const topAreas = ['Coding agents (211)', 'MCP integration (143)', 'Context engineering (116)', 'Agent sandboxing (85)', 'Observability (48)', 'Governance (37)'];
---
<section id="radar" class="section">
  <div class="container">
    <div class="rounded-2xl p-8 sm:p-12 relative overflow-hidden" style="background: linear-gradient(135deg, #ecfdf5, #eff6ff, #f5f3ff); border: 1px solid #e5e7eb;">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald pulse-dot"></span>
        <span class="text-xs font-semibold uppercase tracking-wider text-emerald">Live</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-text" style="font-family: var(--font-heading);">AI Engineering Radar</h2>
      </div>
      <p class="text-text-secondary mb-8 max-w-2xl">
        Tracking the AI engineering ecosystem in real-time. Signals automatically discovered and classified by maturity level.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        {stats.map(stat => (
          <div class="rounded-xl bg-white/70 p-4 text-center">
            <div class="text-2xl sm:text-3xl font-bold text-text" style="font-family: var(--font-heading);">{stat.value}</div>
            <div class="text-xs text-text-muted uppercase tracking-wider mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
      <div class="mb-8">
        <span class="text-xs text-text-muted uppercase tracking-wider block mb-3">Top tracked areas</span>
        <div class="flex flex-wrap gap-2">
          {topAreas.map(area => (
            <span class="text-xs text-text-secondary bg-white/60 border border-border-light rounded-full px-3 py-1">{area}</span>
          ))}
        </div>
      </div>
      <a href="https://visdom-ai-maturity-matrix.pages.dev/dashboard" target="_blank" rel="noopener" class="btn-pill btn-primary">Open AI-Radar Dashboard &rarr;</a>
    </div>
  </div>
</section>
