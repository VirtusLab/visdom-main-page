---
import { HeroSection } from '@virtuslab/visdom-ui';

const actions = [
  { label: 'Explore the Platform', href: '#platform', variant: 'primary' as const },
  { label: 'Take the Assessment', href: 'https://visdom-ai-maturity-matrix.pages.dev/assessment', variant: 'outline' as const, external: true },
];
---
<HeroSection
  title="Your AI agents are only as good as your engineering infrastructure"
  subtitle="Visdom transforms your software delivery lifecycle into an agent-operable production system. From assessment to autonomous delivery."
  badge="AI-Native SDLC Platform"
  actions={actions}
  client:load
/>
