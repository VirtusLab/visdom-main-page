# Google Analytics 4 measurement ID (looks like G-XXXXXXXXXX).
# The site defaults to the production ID, so you only need this to override it,
# e.g. set PUBLIC_GA_ID= (empty) to disable analytics on a preview or locally.
PUBLIC_GA_ID=

# Sentry DSN for front-end error tracking (https://<key>@<org>.ingest.sentry.io/<id>).
# When empty, Sentry is not loaded at all. Set it to enable error reporting.
PUBLIC_SENTRY_DSN=
